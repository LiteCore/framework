{
	"name": "litecore",
	"title": "LiteCore",
	"description": "Lightweight website core framework built with PHP, jQuery and HTML.",
	"version": "1.0.0",
	"author": {
		"name": "T. Almroth",
		"url": "https://litecore.dev/"
	},
	"license": "CC-BY-ND-4.0",
	"homepage": "https://www.litecore.dev/",
	"download": "https://www.litecore.dev/download",
	"repository": {
		"type": "git",
		"url": "git://github.com/litecore/framework.git"
	},
	"bugs": {
		"url": "https://github.com/litecart/litecore/issues"
	},
	"type": "module",
	"engines": {
		"node": ">=24",
		"bun": ">=1.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sequencemedia/gulp-clean-css": "^1.0.285",
		"@sequencemedia/gulp-sourcemaps": "^1.0.301",
		"gulp": "^5.0.1",
		"gulp-clean-css": "^4.3.0",
		"gulp-concat": "^2.6.1",
		"gulp-fetch": "^1.0.1",
		"gulp-header": "^2.0.12",
		"gulp-phplint": "^0.9.0",
		"gulp-rename": "^2.1.0",
		"gulp-replace": "^1.1.4",
		"gulp-sass": "^6.0.1",
		"gulp-uglify": "^3.0.2",
		"gulp-watch": "^5.0.1",
		"phplint": "^2.0.5",
		"sass": "^1.99.0",
		"eslint": "^10.2.1",
		"eslint-plugin-html": "^8.1.4",
		"stylelint": "^17.8.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"postcss-html": "^1.8.1",
		"postcss-scss": "^4.0.9"
	},
	"scripts": {
		"iconly": "gulp iconly && gulp scss-framework",
		"archive": "git archive --format=zip --output latest.zip",
		"build": "gulp build",
		"phplint": "gulp phplint",
		"test": "gulp test",
		"uglify": "gulp replace",
		"watch": "gulp watch",
		"upgrade": "ncu -u && npm install && npm dedupe",
		"dependencies": "npm list --depth=1",
		"lint": "eslint \"public_html/**/*.{js,php,html}\"",
		"lint:css": "stylelint \"public_html/**/*.{php,html}\" --fix --allow-empty-input --custom-syntax postcss-html",
		"lint:scss": "stylelint \"public_html/**/*.scss\" --fix --allow-empty-input --custom-syntax postcss-scss",
		"lint:style": "npm run lint:css && npm run lint:scss"
	}
}
